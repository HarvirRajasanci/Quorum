# War Room Backend Environment Variables
# Copy this file to .env for local development.
# Do not commit .env.

# App
APP_ENV=development
HOST=0.0.0.0
PORT=8000
SESSION_SECRET=replace_with_random_32_char_string
MAX_DEBATE_CYCLES=3

# CORS
# For hackathon development, the backend will allow all origins in code.
# Keep this here so we can tighten it later if needed.
CORS_ALLOW_ORIGINS=*

# LLM endpoint — swap to AMD vLLM when P2 has it live; no code changes needed
# Fallback (now):  LLM_BASE_URL=https://api.deepseek.com  LLM_MODEL=deepseek-chat
# AMD (later):     LLM_BASE_URL=http://YOUR_MI300X_INSTANCE/v1  LLM_MODEL=llama-3.1-70b
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=your_deepseek_api_key_here
LLM_MODEL=deepseek-chat

# AMD Developer Cloud / vLLM (fill in when P2 provisions the instance)
AMD_ENDPOINT=http://YOUR_MI300X_INSTANCE/v1
AMD_TOKEN=your_token_here
AMD_MODEL=llama-3.1-70b

# Market Data
# P2 owns NewsAPI and Yahoo Finance fetcher integration.
NEWS_API_KEY=your_newsapi_key_here

# Redis
# P2 owns Redis setup and memory helpers.
REDIS_URL=redis://localhost:6379

# Risk / debate config
DRAWDOWN_THRESHOLD=0.15

# Demo defaults
DEMO_GPU_NAME=AMD MI300X
DEMO_AGENTS_PARALLEL=7